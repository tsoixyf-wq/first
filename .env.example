# ============================================
# Resume Matcher - Environment Configuration
# ============================================
#
# 本地开发:   所有 host 设为 localhost
# Docker 开发:  所有 host 设为 docker-compose 服务名 (postgres/chromadb/redis/minio/backend)
# Docker 生产:  同 Docker 开发，但 DEBUG=false，移除 --reload
# Render/Railway: 使用各平台提供的连接字符串
# ============================================

# --- Database ---
POSTGRES_USER=resume
POSTGRES_PASSWORD=resume123
POSTGRES_DB=resume_matcher
# 本地开发 → localhost  |  Docker → postgres  |  托管 → 云服务商 host
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- ChromaDB ---
# 本地开发 → localhost  |  Docker → chromadb  |  托管 → Qdrant Cloud endpoint
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# --- Redis ---
# 本地开发 → redis://localhost:6379/0  |  Docker → redis://redis:6379/0  |  托管 → Upstash URL
REDIS_URL=redis://redis:6379/0

# --- MinIO (File Storage) ---
# 本地开发 → localhost:9000  |  Docker → minio:9000  |  托管 → Cloudflare R2 endpoint
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=resumes

# --- LLM Configuration ---
# Provider: deepseek | openai | qwen | ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-deepseek-api-key-here
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:   https://api.openai.com/v1
# Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama:   http://localhost:11434/v1
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# --- NER (Named Entity Recognition) ---
# 启用 GLiNER 零样本实体识别（首次启动需下载 300-500MB 模型）
# LLM 已覆盖同类实体类型且精度更高，生产环境建议保持 false
ENABLE_GLINER=false

# --- Embedding Model ---
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# CPU 服务器 → cpu  |  GPU 服务器 → cuda  |  Apple Silicon → mps
EMBEDDING_DEVICE=cpu

# --- App Settings ---
APP_NAME=Resume Matcher
APP_VERSION=1.0.0
# 本地开发 → true  |  生产 → false (必须!)
DEBUG=true
# 生产: openssl rand -hex 32
SECRET_KEY=change-this-in-production
# API Key 认证 — 留空跳过（开发），生产环境必须设置（openssl rand -hex 32）
API_KEY=
# 本地开发 → http://localhost:3000  |  生产 → 前端域名  |  多个域名用逗号分隔
CORS_ORIGINS=http://localhost:3000

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,md

# --- Frontend (Docker 环境需要) ---
# Docker 生产: NEXT_PUBLIC_API_HOST=backend
# Vercel: 设置 NEXT_PUBLIC_API_URL 环境变量
NEXT_PUBLIC_API_HOST=backend
